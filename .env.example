# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# VAPID Keys (Web Push Notifications)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@example.com

# PagNow (Payment Gateway)
PAGNOW_API_KEY=your_pagnow_api_key_here
PAGNOW_WEBHOOK_URL=https://your-project-id.supabase.co/functions/v1/pagnow-webhook
PAGNOW_WEBHOOK_SECRET=your_pagnow_webhook_secret_here

# Meta Ads / Facebook CAPI
META_TOKEN=your_facebook_capi_token_here
